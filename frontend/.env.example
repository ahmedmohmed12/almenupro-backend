# AlMenuPro Frontend (Vercel) — build-time variables only
# NOTE: Never put ADMIN_AUTH_SECRET or SUPER_ADMIN_PASSWORD in the frontend bundle.
# Authentication is handled server-side via POST /api/auth/login on the backend.

API_BASE_URL=https://almenupro-backend.vercel.app/api

# Optional labels for admin login UI (non-secret defaults only)
SUPER_ADMIN_USER=superadmin
