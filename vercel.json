{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "node scripts/preparePublicUploads.js",
  "functions": {
    "apiServer.js": {
      "includeFiles": [
        "data/**",
        "uploads/menu/**",
        "public/api/uploads/menu/**",
        "lib/menuImageStorage.js"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apiServer.js"
    }
  ]
}
