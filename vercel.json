{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "node scripts/preparePublicUploads.js",
  "builds": [
    {
      "src": "apiServer.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "data/**,uploads/menu/**,public/api/uploads/menu/**,lib/menuImageStorage.js"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/uploads/menu/(.*)",
      "dest": "/api/uploads/menu/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "apiServer.js"
    }
  ]
}
