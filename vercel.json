{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "echo \"No install step for Node API\"",
  "builds": [
    {
      "src": "apiServer.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "data/**,uploads/menu/**,lib/menuImageStorage.js"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apiServer.js"
    }
  ]
}
