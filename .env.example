# AlMenuPro Backend (Vercel) — required environment variables

# Persistent storage (MongoDB Atlas recommended for production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=almenupro

# Admin authentication (change in production)
ADMIN_AUTH_SECRET=replace-with-long-random-secret
SUPER_ADMIN_USER=superadmin
SUPER_ADMIN_PASSWORD=replace-with-strong-password

# Legacy Flask stack (optional)
OPENAI_API_KEY=
FLASK_SECRET_KEY=
DATABASE_PATH=
UPLOAD_DIR=
